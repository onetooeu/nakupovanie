<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin login | nakupovanie.sk</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0b0b0f;
        color: #f5f1ea;
        font-family: Arial, sans-serif;
      }
      .card {
        width: min(520px, calc(100vw - 32px));
        padding: 32px;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 18px;
        background: rgba(255,255,255,.04);
      }
      h1 { margin: 0 0 12px; font-size: 40px; }
      p { margin: 0 0 20px; opacity: .8; }
      label { display: block; margin: 0 0 8px; }
      input {
        width: 100%;
        box-sizing: border-box;
        padding: 14px 16px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.16);
        background: #111318;
        color: #fff;
        font-size: 16px;
      }
      button {
        margin-top: 16px;
        padding: 14px 18px;
        border: 0;
        border-radius: 999px;
        background: #e7c27a;
        color: #111;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
      }
      .hint { margin-top: 14px; font-size: 14px; opacity: .72; }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Sign in</h1>
      <p>Admin login for nakupovanie.sk / nakupovani.cz</p>
      <form action="/api/admin/login" method="post">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" autocomplete="current-password" />
        <button type="submit">Login</button>
      </form>
      <div class="hint">If this page loads, the route is fine and the crash is inside the admin dashboard code.</div>
    </main>
  </body>
</html>