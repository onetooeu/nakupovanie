---
import BaseLayout from '../layouts/BaseLayout.astro';
import { isAdminRequest } from '../lib/auth';
import { getDb, listRegistrations, ensureSchema } from '../lib/db';

const authed = isAdminRequest(Astro.request, Astro.locals.runtime.env);
const lang = 'sk';

let registrations: any[] = [];
if (authed) {
  const db = getDb(Astro.locals.runtime.env);
  await ensureSchema(db);
  registrations = await listRegistrations(db);
}

const statusOrder = [
  'new',
  'confirmed',
  'shortlisted',
  'posted',
  'buy_now_interest',
  'auction_interest',
  'inactive',
  'won',
  'lost',
] as const;

const statusCounts = Object.fromEntries(
  statusOrder.map((status) => [
    status,
    registrations.filter((row) => row.status === status).length,
  ]),
);

const yesNo = (value: any) => (value ? 'Yes' : 'No');
---

<BaseLayout
  lang={lang}
  title="Admin | nakupovanie.sk / nakupovani.cz"
  description="Admin panel for registrations"
>
  <main class="admin-wrap">
    <div class="container">
      {authed ? (
        <div class="stack">
          <div class="card">
            <div class="card-inner">
              <div class="kicker">Admin panel</div>
              <h1 class="h2" style="margin-top:8px;">Registrations</h1>
              <p class="small">
                Simple internal dashboard for company leads, statuses, notes, and TFWS-aligned workflow.
              </p>
              <div class="btn-row">
                <a class="btn btn-secondary" href="/api/admin/export.csv">Export CSV</a>
                <a class="btn btn-secondary" href="/api/admin/export.json">Export JSON</a>
                <a class="btn btn-secondary" href="/api/admin/logout">Logout</a>
              </div>
            </div>
          </div>

          <div class="grid grid-3">
            <div class="card">
              <div class="card-inner">
                <div class="kicker">Total registrations</div>
                <h3 style="margin: 8px 0 0; font-size: 2rem;">{registrations.length}</h3>
              </div>
            </div>

            {statusOrder.slice(0, 2).map((status) => (
              <div class="card">
                <div class="card-inner">
                  <div class="kicker">{status}</div>
                  <h3 style="margin: 8px 0 0; font-size: 2rem;">{statusCounts[status] ?? 0}</h3>
                </div>
              </div>
            ))}
          </div>

          <div class="admin-grid">
            <div class="table-admin card">
              <table>
                <thead>
                  <tr>
                    <th>Company</th>
                    <th>Contact</th>
                    <th>Status</th>
                    <th>Created</th>
                  </tr>
                </thead>
                <tbody>
                  {registrations.map((row) => (
                    <>
                      <tr>
                        <td>
                          <strong>{row.company_name}</strong>
                          <br />
                          <span class="small">IČO: {row.company_id}</span>
                          <br />
                          <span class="small">Country: {row.country}</span>
                          <br />
                          <span class="small">Industry: {row.industry}</span>
                        </td>

                        <td>
                          <div class="small">{row.contact_name}</div>
                          <div class="small">{row.contact_position}</div>
                          <div class="small">{row.email}</div>
                          <div class="small">{row.phone}</div>
                        </td>

                        <td>
                          <form
                            method="post"
                            action={`/api/admin/registration/${row.id}`}
                            class="stack"
                            style="gap:10px;"
                          >
                            <input type="hidden" name="field" value="status" />
                            <select name="value">
                              {statusOrder.map((status) => (
                                <option value={status} selected={row.status === status}>
                                  {status}
                                </option>
                              ))}
                            </select>
                            <button class="btn btn-secondary" type="submit">Update</button>
                          </form>
                        </td>

                        <td class="small">{row.created_at}</td>
                      </tr>

                      <tr>
                        <td colspan="4" style="padding-top:0;">
                          <div class="card" style="margin: 0 0 18px;">
                            <div class="card-inner" style="padding-top: 18px;">
                              <div class="kicker">Full registration details</div>

                              <div
                                class="grid"
                                style="grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin-top: 16px;"
                              >
                                <div>
                                  <div class="small" style="opacity:.6;">Company name</div>
                                  <div>{row.company_name || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Company ID</div>
                                  <div>{row.company_id || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Contact name</div>
                                  <div>{row.contact_name || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Contact position</div>
                                  <div>{row.contact_position || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Email</div>
                                  <div>{row.email || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Phone</div>
                                  <div>{row.phone || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Country</div>
                                  <div>{row.country || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Company website</div>
                                  <div>{row.company_website || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Industry</div>
                                  <div>{row.industry || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Status</div>
                                  <div>{row.status || '—'}</div>
                                </div>

                                <div style="grid-column: 1 / -1;">
                                  <div class="small" style="opacity:.6;">Delivery address</div>
                                  <div>{row.delivery_address || '—'}</div>
                                </div>

                                <div style="grid-column: 1 / -1;">
                                  <div class="small" style="opacity:.6;">Usage note</div>
                                  <div>{row.usage_note || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Consent data</div>
                                  <div>{yesNo(row.consent_data)}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Consent contact</div>
                                  <div>{yesNo(row.consent_contact)}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Consent terms</div>
                                  <div>{yesNo(row.consent_terms)}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Created at</div>
                                  <div>{row.created_at || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Updated at</div>
                                  <div>{row.updated_at || '—'}</div>
                                </div>

                                <div style="grid-column: 1 / -1;">
                                  <div class="small" style="opacity:.6;">Admin note</div>
                                  <div>{row.admin_note || '—'}</div>
                                </div>

                                <div>
                                  <div class="small" style="opacity:.6;">Last contact at</div>
                                  <div>{row.last_contact_at || '—'}</div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </td>
                      </tr>
                    </>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="stack">
              <div class="card">
                <div class="card-inner">
                  <h2 style="margin-top:0;">Quick actions</h2>
                  <p class="small">
                    Use the row forms to update statuses. Notes and last-contact timestamps can be set from the detail endpoint.
                  </p>
                </div>
              </div>

              <div class="card">
                <div class="card-inner">
                  <h2 style="margin-top:0;">TFWS hooks</h2>
                  <p class="small">
                    After publishing, generate the hash inventory and keep `/.well-known` aligned with the trust manifest.
                    The site already ships the TFWS scaffold.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <div class="card" style="max-width: 560px; margin-inline:auto;">
          <div class="card-inner">
            <div class="kicker">Admin login</div>
            <h1 class="h2">Sign in</h1>
            <form class="form" action="/api/admin/login" method="post">
              <div class="field">
                <label for="password">Password</label>
                <input id="password" name="password" type="password" autocomplete="current-password" />
              </div>
              <button class="btn btn-primary" type="submit">Login</button>
            </form>
            <p class="small" style="margin-top: 14px;">
              Set ADMIN_PASSWORD and ADMIN_COOKIE_SECRET in .dev.vars or Cloudflare secrets.
            </p>
          </div>
        </div>
      )}
    </div>
  </main>
</BaseLayout>