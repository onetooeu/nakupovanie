---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteCopy } from '../../data/siteCopy';
import { normalizeLang } from '../../lib/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'sk' } }, { params: { lang: 'cz' } }, { params: { lang: 'en' } }];
}

const lang = normalizeLang(Astro.params.lang);
const copy = siteCopy[lang];
---

<BaseLayout lang={lang} title={`${copy.privacy.title} | ${copy.nav.logo}`} description={copy.privacy.intro} canonical={`/${lang}/privacy`}>
  <main class="page-shell">
    <div class="container stack">
      <div class="kicker">{copy.privacy.title}</div>
      <h1 class="h1" style="font-size: clamp(2.4rem, 6vw, 4.5rem);">{copy.privacy.title}</h1>
      <p class="lead">{copy.privacy.intro}</p>

      {copy.privacy.sections.map((section) => (
        <section class="card">
          <div class="card-inner">
            <h2 style="margin-top:0;">{section.title}</h2>
            {section.body.map((p) => <p class="muted">{p}</p>)}
          </div>
        </section>
      ))}

      <section class="card">
        <div class="card-inner">
          <h2 style="margin-top:0;">{copy.privacy.contactTitle}</h2>
          <p class="muted">{copy.privacy.contactBody}</p>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
