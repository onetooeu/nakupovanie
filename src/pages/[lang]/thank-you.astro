---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteCopy } from '../../data/siteCopy';
import { normalizeLang } from '../../lib/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'sk' } }, { params: { lang: 'cz' } }, { params: { lang: 'en' } }];
}

const lang = normalizeLang(Astro.params.lang);
const copy = siteCopy[lang];
const mail = Astro.url.searchParams.get('mail');
const mailMessage = mail === 'sent'
  ? { sk: 'Potvrdzovací email bol odoslaný.', cz: 'Potvrzovací email byl odeslán.', en: 'The confirmation email was sent.' }[lang]
  : mail === 'skipped'
    ? { sk: 'Emailové odosielanie ešte nie je nakonfigurované. Správa je uložená v admin logu.', cz: 'E-mailové odesílání ještě není nakonfigurováno. Zpráva je uložená v admin logu.', en: 'Email delivery is not configured yet. The message is stored in the admin log.' }[lang]
    : mail === 'error'
      ? { sk: 'Emailový provider vrátil chybu. Skontroluj admin log.', cz: 'Emailový provider vrátil chybu. Zkontroluj admin log.', en: 'The email provider returned an error. Check the admin log.' }[lang]
      : null;
---

<BaseLayout lang={lang} title={`${copy.thankYou.title} | ${copy.nav.logo}`} description={copy.thankYou.intro} canonical={`/${lang}/thank-you`}>
  <main class="page-shell">
    <div class="container">
      <div class="card">
        <div class="card-inner">
          <div class="kicker">{copy.thankYou.title}</div>
          <h1 class="h1" style="font-size: clamp(2rem, 4.3vw, 3.6rem); max-width: 16ch;">{copy.thankYou.title}</h1>
          <p class="lead" style="max-width: 62ch;">{copy.thankYou.intro}</p>

          <div class="soft-panel" style="margin-top: 24px; padding: 20px 22px;">
            <div class="badge">Kontakt</div>
            <p class="lead" style="margin: 12px 0 0;">{copy.thankYou.contactText}</p>
          </div>

          {mailMessage ? (
            <div class="notice" style="margin-top: 18px;">{mailMessage}</div>
          ) : null}

          <div class="btn-row">
            <a class="btn btn-primary" href={`/${lang}`}>{copy.thankYou.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
