---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SitePage from '../../components/SitePage.astro';
import { siteCopy } from '../../data/siteCopy';
import { normalizeLang } from '../../lib/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'sk' } }, { params: { lang: 'cz' } }, { params: { lang: 'en' } }];
}

const lang = normalizeLang(Astro.params.lang);
const copy = siteCopy[lang];
---

<BaseLayout
  lang={lang}
  title={`${copy.nav.logo} | ${copy.hero.subtitle}`}
  description={copy.hero.subtitle}
  canonical={`/${lang}`}
>
  <SitePage copy={copy} />
</BaseLayout>
